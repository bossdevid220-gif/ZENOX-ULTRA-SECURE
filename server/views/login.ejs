<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZENOX ULTRA SECURE</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            background: #0a0618;
            font-family: system-ui, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .login-card {
            background: #1a0a3e;
            border-radius: 24px;
            padding: 40px;
            border: 1px solid rgba(255,107,0,0.3);
            width: 100%;
            max-width: 400px;
            box-shadow: 0 20px 60px rgba(255,107,0,0.15);
            position: relative;
            overflow: hidden;
        }
        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #ff6b00, #e05e00, #ff6b00);
            background-size: 200% 100%;
            animation: shimmer 3s linear infinite;
        }
        @keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
        .login-card h1 { color: #ff6b00; font-size: 24px; text-align: center; font-weight: 900; letter-spacing: 2px; }
        .login-card .sub { color: #7c6ba0; text-align: center; font-size: 12px; margin-bottom: 24px; letter-spacing: 1px; }
        .input-group { margin-bottom: 16px; }
        .input-group label { display: block; font-size: 10px; font-weight: 700; color: #7c6ba0; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; }
        .input-group input {
            width: 100%;
            padding: 12px 16px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,107,0,0.2);
            border-radius: 10px;
            color: #fff;
            font-size: 14px;
            letter-spacing: 0.5px;
        }
        .input-group input:focus { outline: none; border-color: #ff6b00; box-shadow: 0 0 20px rgba(255,107,0,0.1); }
        .error {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.2);
            border-radius: 10px;
            padding: 10px 14px;
            color: #ef4444;
            font-size: 12px;
            margin-bottom: 16px;
            text-align: center;
        }
        .btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #ff6b00, #e05e00);
            border: none;
            border-radius: 12px;
            color: #fff;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        .btn:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(255,107,0,0.3); }
        .device-id {
            background: rgba(255,255,255,0.03);
            border-radius: 10px;
            padding: 10px 14px;
            margin-bottom: 16px;
            font-family: monospace;
            font-size: 12px;
            color: #ff6b00;
            text-align: center;
            border: 1px solid rgba(255,107,0,0.15);
            letter-spacing: 0.5px;
        }
        .footer { text-align: center; margin-top: 16px; font-size: 10px; color: #3d2d5a; letter-spacing: 1px; }
        .secure-badge {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin-top: 12px;
            flex-wrap: wrap;
        }
        .secure-badge span {
            font-size: 9px;
            color: #3d2d5a;
            letter-spacing: 0.5px;
        }
    </style>
</head>
<body>
<div class="login-card">
    <h1>🔐 ZENOX</h1>
    <p class="sub">ULTRA SECURE AUTHENTICATION</p>
    
    <div class="device-id" id="deviceIdDisplay"><%= deviceId %></div>
    
    <% if (error) { %>
        <div class="error"><%= error %></div>
    <% } %>
    
    <form action="/login" method="POST" id="loginForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="deviceId" id="deviceIdInput" value="<%= deviceId %>">
        
        <div class="input-group">
            <label>🔑 ACCESS KEY</label>
            <input type="password" name="password" id="passwordInput" placeholder="••••••••••••••••" required autocomplete="off">
        </div>
        
        <button type="submit" class="btn" id="loginBtn">SECURE ACCESS</button>
    </form>
    
    <div class="secure-badge">
        <span>🔒 256-BIT ENCRYPTION</span>
        <span>🛡️ CSRF PROTECTED</span>
        <span>⚡ RATE LIMITED</span>
    </div>
    
    <div class="footer">ZENOX ULTRA SECURE V2.0</div>
</div>

<script>
    // ============================================================
    // DEVICE ID - Already set from backend (no generation needed)
    // ============================================================
    console.log('🔑 DEVICE ID FROM SERVER:', document.getElementById('deviceIdInput').value);
    
    // ============================================================
    // FORM VALIDATION
    // ============================================================
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('loginForm');
        const passwordInput = document.getElementById('passwordInput');
        const deviceIdInput = document.getElementById('deviceIdInput');
        
        form.addEventListener('submit', function(e) {
            // Check if device ID exists
            if (!deviceIdInput.value || deviceIdInput.value === '') {
                e.preventDefault();
                alert('⚠️ DEVICE ID MISSING. PLEASE REFRESH THE PAGE.');
                return false;
            }
            
            // Check if password is entered
            if (!passwordInput.value || passwordInput.value === '') {
                e.preventDefault();
                alert('⚠️ PLEASE ENTER YOUR ACCESS KEY');
                passwordInput.focus();
                return false;
            }
            
            console.log('🔐 SUBMITTING - Device ID:', deviceIdInput.value);
            console.log('🔐 SUBMITTING - Password:', passwordInput.value ? '✓' : '✗');
            return true;
        });
        
        // Enter key support
        passwordInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                form.submit();
            }
        });
    });
</script>
</body>
</html>
